# =========================================================================
# Multivista Printers - Environment Configuration Template
# =========================================================================
# Copy this file to '.env' or '.env.local' and fill in your actual values.
# Do NOT commit files containing actual secrets/credentials to source control.
# =========================================================================

# -------------------------------------------------------------------------
# 1. API Configurations
# -------------------------------------------------------------------------
# GEMINI_API_KEY: Required for Google Gemini AI API integration.
# In Google AI Studio runtime, this is automatically injected from user secrets.
# For local development, get your key from: https://aistudio.google.com/
GEMINI_API_KEY="your-gemini-api-key-here"

# -------------------------------------------------------------------------
# 2. Application & Server Settings
# -------------------------------------------------------------------------
# APP_URL: The public/base URL where this app is hosted or run.
# In AI Studio production, this is set automatically to the Cloud Run service URL.
APP_URL="http://localhost:3000"

# PORT: The port on which the development server or express server should run.
PORT=3000

# -------------------------------------------------------------------------
# 3. Development / Tooling Settings
# -------------------------------------------------------------------------
# DISABLE_HMR: Set to 'true' to disable Hot Module Replacement (HMR) and file 
# watching. This reduces CPU usage in certain development environments (e.g. AI Studio).
DISABLE_HMR=false
